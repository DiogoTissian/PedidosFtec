@model List<PedidoModel>

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div class="page-container">

    <div class="list-card">

        <h1>Seus Pedidos</h1>

        @if (Model != null && Model.Count > 0)
        {
            <div class="pedidos-list">

                @foreach (PedidoModel pedido in Model.Where(a => a.UsuarioId == DadosTeste.usuarioLogado.id && a.StatusPedido == 0))
                {
                    <div class="pedido-card">

                        <div class="pedido-info">
                            <span class="label">Data do Pedido</span>
                            <span class="value">
                                @pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")
                            </span>
                        </div>

                        <div class="pedido-info">
                            <span class="label">Valor Total</span>
                            <span class="value">
                                R$ @pedido.ValorTotal
                            </span>
                        </div>

                        <div class="action-buttons">
                            <a class="btn-excluir"
                               asp-controller="Pedido"
                               asp-action="Remover"
                               asp-route-id="@pedido.Id">
                                Cancelar
                            </a>
                            <a class="btn-pagar"
                               asp-controller="Pagamento"
                               asp-action="MostrarPagamento"
                               asp-route-pedidoId="@pedido.Id">
                                Pagar
                            </a>
                        </div>

                    </div>
                }

            </div>
        }
        else
        {
            <div class="sem-registros">
                Nenhum pedido encontrado.
            </div>
        }

    </div>

</div>

<style>
    body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: #f4f6f9;
    }

    .page-container {
        padding: 30px;
        display: flex;
        justify-content: center;
    }

    .list-card {
        width: 100%;
        max-width: 900px;
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,.15);
    }

        .list-card h1 {
            text-align: center;
            margin-bottom: 25px;
            color: #333;
        }

    .pedidos-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .pedido-card {
        border: 1px solid #e5e5e5;
        border-radius: 10px;
        padding: 20px;
        background: #fff;
        transition: .3s;
    }

        .pedido-card:hover {
            box-shadow: 0 4px 12px rgba(0,0,0,.08);
        }

    .pedido-info {
        display: flex;
        flex-direction: column;
        margin-bottom: 12px;
    }

    .label {
        font-weight: bold;
        color: #555;
        margin-bottom: 4px;
    }

    .value {
        color: #333;
        font-size: 15px;
    }

    .action-buttons {
        display: flex;
        gap: 10px;
        margin-top: 15px;
    }

    .btn-excluir,
    .btn-pagar {
        flex: 1;
        padding: 12px;
        text-align: center;
        text-decoration: none;
        border-radius: 6px;
        font-weight: bold;
        color: white;
        transition: .3s;
    }

    .btn-excluir {
        background: #dc3545;
    }

        .btn-excluir:hover {
            background: #c82333;
        }

    .btn-pagar {
        background: #28a745;
    }

        .btn-pagar:hover {
            background: #218838;
        }

    .sem-registros {
        text-align: center;
        padding: 30px;
        color: #666;
        font-size: 16px;
    }
</style>