@model UsuarioModel
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div class="login-container">
    <div class="login-card cadastro-card">
        <h2>Editar Conta</h2>

        <form method="post" asp-controller="Usuario" asp-action="CriarConta">

            <input type="hidden" name="usuario.id" value="@Model.id" />
            <input type="hidden" name="usuario.senha" value="@Model.senha" />

            <div class="form-group">
                <label>Nome</label>
                <input type="text" name="usuario.nome" value="@Model.nome" />
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="text" name="usuario.email" value="@Model.email" />
            </div>

            <div class="form-group">
                <label>Telefone</label>
                <input type="text" name="usuario.telefone" value="@Model.telefone" />
            </div>

            <div class="form-group">
                <label>Data Nascimento</label>
                <input type="date" name="usuario.dataNascimento" value="@Model.dataNascimento.ToString("yyyy-MM-dd")" />
            </div>

            <div class="botoes">
                <input type="submit" value="Salvar" class="btn-login" />

                <a asp-controller="Produto"
                   asp-action="Index"
                   class="btn-cancelar">
                    Cancelar
                </a>
            </div>

        </form>
    </div>
</div>

<style>
    body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: #f4f6f9;
    }

    .login-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .cadastro-card {
        width: 450px;
    }

    .login-card {
        background: white;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    }

        .login-card h2 {
            text-align: center;
            margin-bottom: 30px;
            color: #333;
        }

    .form-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 18px;
    }

        .form-group label {
            margin-bottom: 6px;
            font-weight: bold;
            color: #555;
        }

        .form-group input,
        .form-group select {
            padding: 12px;
            border: 1px solid #dcdcdc;
            border-radius: 6px;
            font-size: 14px;
            box-sizing: border-box;
            transition: .3s;
        }

            .form-group input:focus,
            .form-group select:focus {
                outline: none;
                border-color: #0078d7;
                box-shadow: 0 0 5px rgba(0,120,215,0.3);
            }

    .botoes {
        display: flex;
        gap: 10px;
        margin-top: 25px;
    }

    .btn-login,
    .btn-cancelar {
        flex: 1;
        padding: 12px;
        border-radius: 6px;
        text-align: center;
        text-decoration: none;
        font-weight: bold;
        font-size: 15px;
        cursor: pointer;
        box-sizing: border-box;
    }

    .btn-login {
        background: #0078d7;
        color: white;
        border: none;
    }

        .btn-login:hover {
            background: #005fa3;
        }

    .btn-cancelar {
        background: #e0e0e0;
        color: #333;
        border: 1px solid #ccc;
    }

        .btn-cancelar:hover {
            background: #d0d0d0;
        }
</style>