    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div class="login-container">
    <div class="login-card">
        <h2>Login</h2>

        <form method="post" asp-controller="Usuario" asp-action="Login">
            <div class="form-group">
                <label>Email</label>
                <input type="text" name="usuario.Email" />
            </div>

            <div class="form-group">
                <label>Senha</label>
                <input type="password" name="usuario.Senha" />
            </div>

            <input type="submit" value="Entrar" class="btn-login" />
        </form>

        @if (!ViewBag.usuarioEncontrado)
        {
            <div class="erro">
                Erro ao realizar operação com login/cadastro de usuário
            </div>
        }

        <div class="criar-conta">
            <a asp-controller="Usuario" asp-action="Create">
                Criar conta
            </a>
        </div>
    </div>
</div>

<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #f1f3f6;
    }

    .login-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 25px;
        display: flex;
        justify-content: center;
    }

    .login-card {
        width: 420px;
        background: white;
        border-radius: 12px;
        padding: 35px;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        transition: .25s;
    }

        .login-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,.15);
        }

        .login-card h2 {
            margin: 0 0 25px;
            text-align: center;
            font-size: 28px;
            color: #333;
        }

    .form-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 18px;
    }

        .form-group label {
            margin-bottom: 8px;
            font-weight: bold;
            color: #555;
        }

        .form-group input {
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
            transition: .2s;
        }

            .form-group input:focus {
                outline: none;
                border-color: #ff6a00;
                box-shadow: 0 0 5px rgba(255,106,0,.3);
            }

    .btn-login {
        width: 100%;
        padding: 12px;
        background: #ff6a00;
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-size: 15px;
        font-weight: bold;
        transition: .2s;
    }

        .btn-login:hover {
            background: #e85f00;
        }

    .erro {
        margin-top: 18px;
        padding: 12px;
        background: #fdecea;
        color: #d32f2f;
        border-radius: 8px;
        text-align: center;
        font-size: 14px;
    }

    .criar-conta {
        margin-top: 20px;
        text-align: center;
    }

        .criar-conta a {
            display: inline-block;
            background: #28a745;
            color: white;
            padding: 12px 18px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: bold;
            transition: .2s;
        }

            .criar-conta a:hover {
                background: #218838;
            }
</style>