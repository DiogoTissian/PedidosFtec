@model AvaliacaoModel

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div class="page-container">
    <div class="form-card">

        <h1>Editar Avaliação</h1>

        <form method="post" asp-controller="Avaliacao" asp-action="Inserir">

            <input name="avaliacao.Id"
                   type="hidden"
                   value="@Model.Id" />

            <input name="avaliacao.idCliente"
                   type="hidden"
                   value="@Model.idCliente" />

            <input name="avaliacao.idProduto"
                   type="hidden"
                   value="@Model.idProduto" />

            <div class="form-group">
                <label>Nota (0 a 10)</label>
                <input name="avaliacao.Nota"
                       type="number"
                       min="0"
                       max="10"
                       value="@Model.Nota" />
            </div>

            <div class="form-group">
                <label>Descrição</label>
                <input name="avaliacao.Descricao"
                       type="text"
                       value="@Model.Descricao" />
            </div>

            <div class="action-buttons">

                <button type="submit" class="btn-salvar">
                    Salvar
                </button>

                <a class="btn-excluir"
                   asp-controller="Avaliacao"
                   asp-action="Remover"
                   asp-route-id="@Model.Id"
                   asp-route-produtoId="@Model.idProduto">
                    Remover
                </a>

                <a class="btn-cancelar"
                   asp-controller="Avaliacao"
                   asp-action="AvaliacoesProduto"
                   asp-route-produtoId="@Model.idProduto">
                    Cancelar
                </a>

            </div>

        </form>

    </div>
</div>

<style>
    body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: #f4f6f9;
    }

    .page-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .form-card {
        width: 100%;
        max-width: 450px;
        background: white;
        padding: 35px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,.15);
    }

        .form-card h1 {
            text-align: center;
            margin-bottom: 25px;
            color: #333;
        }

    .form-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 18px;
    }

        .form-group label {
            margin-bottom: 6px;
            font-weight: bold;
            color: #555;
        }

        .form-group input {
            padding: 12px;
            border: 1px solid #dcdcdc;
            border-radius: 6px;
            font-size: 14px;
            transition: .3s;
        }

            .form-group input:focus {
                outline: none;
                border-color: #0078d7;
                box-shadow: 0 0 5px rgba(0,120,215,.3);
            }

    .action-buttons {
        display: flex;
        gap: 10px;
        margin-top: 25px;
        flex-wrap: wrap;
    }

    .btn-salvar,
    .btn-cancelar,
    .btn-excluir {
        flex: 1;
        padding: 12px;
        border-radius: 6px;
        text-align: center;
        text-decoration: none;
        font-weight: bold;
        cursor: pointer;
        transition: .3s;
    }

    .btn-salvar {
        background: #28a745;
        color: white;
        border: none;
    }

        .btn-salvar:hover {
            background: #218838;
        }

    .btn-cancelar {
        background: #6c757d;
        color: white;
    }

        .btn-cancelar:hover {
            background: #5a6268;
        }

    .btn-excluir {
        background: #dc3545;
        color: white;
    }

        .btn-excluir:hover {
            background: #c82333;
        }
</style>