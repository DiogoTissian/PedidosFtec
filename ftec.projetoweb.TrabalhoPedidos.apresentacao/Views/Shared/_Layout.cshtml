<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - ftec.projetoweb.TrabalhoPedidos.apresentacao</title>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/ftec.projetoweb.TrabalhoPedidos.apresentacao.styles.css" asp-append-version="true" />
</head>
<body>
	<header>
		<nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
			<div class="container-fluid">
				<a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Aplicativo Loja</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
						aria-expanded="false" aria-label="Toggle navigation">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
					<ul class="navbar-nav flex-grow-1">
						<li class="nav-item">
							<a class="nav-link text-dark" asp-area="" asp-controller="Produto" asp-action="Index">Produtos</a>
						</li>

						@if (DadosTeste.usuarioLogado != null)
						{
							<li class="nav-item">
								<a class="nav-link text-dark" asp-area="" asp-controller="Pedido" asp-action="Index">Pedidos</a>
							</li>

							if (DadosTeste.usuarioLogado.funcao == 0)
							{

							}
							else if (DadosTeste.usuarioLogado.funcao == 2)
							{
								<li class="nav-item">
									<a class="nav-link text-dark" asp-area="" asp-controller="Estatistica" asp-action="Index">Estatísticas</a>
								</li>
								<li class="nav-item">
									<a class="nav-link text-dark" asp-area="" asp-controller="Categoria" asp-action="Index">Categorias</a>
								</li>
							}
							else if (DadosTeste.usuarioLogado.funcao == 0 || DadosTeste.usuarioLogado.funcao == 2)
							{
								<li class="nav-item">
									<a class="nav-link text-dark" asp-area="" asp-controller="Pagamento" asp-action="Index">Pagamentos</a>
								</li>
							}
							<li class="nav-item">
								<a class="nav-link text-dark" asp-area="" asp-controller="Usuario" asp-action="Edit">Editar Usuário</a>
							</li>
							<li class="nav-item">
								<a class="nav-link text-dark" asp-area="" asp-controller="Usuario" asp-action="Logoff">Logoff</a>
							</li>
						}
						else
						{
							<li class="nav-item">
								<a class="nav-link text-dark" asp-area="" asp-controller="Usuario" asp-action="Index">Login</a>
							</li>
						}
					</ul>
				</div>
			</div>
		</nav>
	</header>
	<div class="container">
		<main role="main" class="pb-3">
			@RenderBody()
		</main>
	</div>

	<footer class="border-top footer text-muted">
		<div class="container">
			&copy; 2026 - ftec.projetoweb.TrabalhoPedidos.apresentacao - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
		</div>
	</footer>
	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
