@model ProdutosListagemModel

<div class="market-container">

    <div class="market-header">

        <h1>Catálogo de Produtos</h1>

        <div class="search-bar">
            <input type="text"
                   id="pesquisaProduto"
                   placeholder="Buscar produtos..." />
            <button id="btn-buscar">Buscar</button>
        </div>

        @if (DadosTeste.usuarioLogado != null && (DadosTeste.usuarioLogado.funcao == 1 || DadosTeste.usuarioLogado.funcao == 2))
        {
            <a class="btn-add"
               asp-controller="Produto"
               asp-action="Create">
                + Novo Produto
            </a>
        }
    </div>

    @if (Model?.Produtos?.Any() == true)
    {
        <div class="grid-products">

            @foreach (ProdutoModel produto in Model.Produtos.Where(x => x.Disponivel))
            {
                <div class="product-card" data-nome="@produto.Nome">

                    <div class="product-image">
                        🛒
                    </div>

                    <div class="product-info" data-categoria="@produto.IdCategoria">

                        <h3>@produto.Nome</h3>

                        <p class="desc">@produto.Descricao</p>

                        <div class="price">
                            R$ @produto.Preco
                        </div>

                        <small class="code">Cód: @produto.Codigo</small>

                        <div class="actions">

                            @if (DadosTeste.usuarioLogado != null && DadosTeste.usuarioLogado.funcao == 2)
                            {
                                <a class="btn-edit"
                                   asp-controller="Produto"
                                   asp-action="Edit"
                                   asp-route-id="@produto.Id">
                                    Editar
                                </a>
                            }
                            
                            <a class="btn-view"
                               asp-controller="Produto"
                               asp-action="Visualizar"
                               asp-route-id="@produto.Id">
                                Ver
                            </a>

                        </div>

                    </div>
                </div>
            }

        </div>
    }
    else
    {
        <div class="empty">
            Nenhum produto disponível no momento.
        </div>
    }

</div>

<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #f1f3f6;
    }

    .market-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 25px;
    }

    .market-header {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin-bottom: 25px;
    }

        .market-header h1 {
            margin: 0;
            font-size: 28px;
            color: #333;
        }

    .search-bar {
        display: flex;
        gap: 10px;
    }

        .search-bar input {
            flex: 1;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #ddd;
            font-size: 14px;
        }

            .search-bar input:focus {
                outline: none;
                border-color: #ff6a00;
                box-shadow: 0 0 5px rgba(255,106,0,.3);
            }

        .search-bar button {
            padding: 12px 20px;
            background: #ff6a00;
            border: none;
            color: white;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
        }

            .search-bar button:hover {
                background: #e85f00;
            }

    .btn-add {
        background: #28a745;
        color: white;
        padding: 12px 16px;
        border-radius: 8px;
        text-decoration: none;
        width: fit-content;
        font-weight: bold;
    }

        .btn-add:hover {
            background: #218838;
        }

    .grid-products {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
        gap: 18px;
    }

    .product-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        transition: .25s;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,.15);
        }

    .product-image {
        height: 140px;
        background: linear-gradient(135deg, #ff6a00, #ffb347);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
    }

    .product-info {
        padding: 15px;
    }

        .product-info h3 {
            margin: 0 0 8px;
            font-size: 16px;
            color: #333;
        }

    .desc {
        font-size: 13px;
        color: #666;
        height: 35px;
        overflow: hidden;
    }

    .price {
        margin-top: 10px;
        font-size: 20px;
        font-weight: bold;
        color: #2e7d32;
    }

    .code {
        display: block;
        margin-top: 5px;
        color: #999;
        font-size: 12px;
    }

    .actions {
        display: flex;
        gap: 8px;
        margin-top: 12px;
    }

        .actions a {
            flex: 1;
            text-align: center;
            padding: 10px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: bold;
            font-size: 13px;
        }

    .btn-view {
        background: #007bff;
        color: white;
    }

        .btn-view:hover {
            background: #0069d9;
        }

    .btn-edit {
        background: #ffc107;
        color: #333;
    }

        .btn-edit:hover {
            background: #e0a800;
        }

    .empty {
        text-align: center;
        padding: 50px;
        color: #777;
        font-size: 16px;
    }
</style>

<script src="~/lib/jquery/dist/jquery.min.js"></script>

<script>

    $("#btn-buscar").on("click", function () {
        $(".product-card").each(function () {
            $(this).hide();
        });

        let termo = $("#pesquisaProduto").val().toLowerCase().trim();

        $(".product-card").each(function () {

            let nome = $(this).data("nome").toLowerCase();

            if (termo === "" || nome.includes(termo)) {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
    });

</script>