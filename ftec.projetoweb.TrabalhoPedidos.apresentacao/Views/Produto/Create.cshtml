@model List<CategoriaModel>

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div class="page-container">
    <div class="form-card">

        <h1>Novo Produto</h1>

        <form method="post"
              asp-controller="Produto"
              asp-action="Inserir">

            <div class="form-group">
                <label>Categoria</label>
                <select name="produto.IdCategoria">
                    <option selected value="0"></option>
                    @foreach(CategoriaModel categoria in Model){
                        <option value="@categoria.Id">@categoria.Nome</option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Nome</label>
                <input type="text"
                       name="produto.Nome"
                       required />
            </div>

            <div class="form-group">
                <label>Estoque Mínimo para Venda</label>
                <input type="number"
                       min="1"
                       name="produto.EstoqueMinimoVenda"
                       required />
            </div>

            <div class="form-group">
                <label>Quantidade em Estoque</label>
                <input type="number"
                       min="1"
                       name="produto.QuantidadeEstoque"
                       required />
            </div>

            <div class="form-group">
                <label>Preço</label>
                <input id="produtoPreco"
                       type="text"
                       name="produto.Preco"
                       onblur="validarDecimal()"
                       required />
            </div>

            <input type="hidden"
                   name="produto.Disponivel"
                   value="true" />

            <input type="hidden"
                   name="produto.Excluido"
                   value="false" />

            <div class="form-group">
                <label>Código</label>
                <input type="text"
                       name="produto.Codigo"
                       required />
            </div>

            <div class="form-group">
                <label>Descrição</label>
                <textarea name="produto.Descricao"
                          rows="4"></textarea>
            </div>

            <div class="action-buttons">

                <button type="submit" class="btn-salvar">
                    Cadastrar
                </button>

                <a class="btn-cancelar"
                   asp-controller="Produto"
                   asp-action="Index">
                    Cancelar
                </a>

            </div>

        </form>

    </div>
</div>

<style>
    body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: #f4f6f9;
    }

    .page-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .form-card {
        width: 100%;
        max-width: 550px;
        background: #fff;
        padding: 35px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,.15);
    }

        .form-card h1 {
            text-align: center;
            margin-bottom: 25px;
            color: #333;
        }

    .form-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 18px;
    }

        .form-group label {
            margin-bottom: 6px;
            font-weight: bold;
            color: #555;
        }

        .form-group input,
        .form-group textarea {
            padding: 12px;
            border: 1px solid #dcdcdc;
            border-radius: 6px;
            font-size: 14px;
            transition: .3s;
            resize: vertical;
        }

            .form-group input:focus,
            .form-group textarea:focus {
                outline: none;
                border-color: #0078d7;
                box-shadow: 0 0 5px rgba(0,120,215,.3);
            }

    .action-buttons {
        display: flex;
        gap: 10px;
        margin-top: 25px;
    }

    .btn-salvar,
    .btn-cancelar {
        flex: 1;
        padding: 12px;
        border-radius: 6px;
        text-align: center;
        text-decoration: none;
        font-weight: bold;
        cursor: pointer;
        transition: .3s;
    }

    .btn-salvar {
        background: #28a745;
        color: white;
        border: none;
    }

        .btn-salvar:hover {
            background: #218838;
        }

    .btn-cancelar {
        background: #6c757d;
        color: white;
    }

        .btn-cancelar:hover {
            background: #5a6268;
        }

    .form-group select {
        padding: 12px;
        border: 1px solid #dcdcdc;
        border-radius: 6px;
        font-size: 14px;
        transition: .3s;
        resize: vertical;
        width: 100%;
        background: #fff;
    }

        .form-group select:focus {
            outline: none;
            border-color: #0078d7;
            box-shadow: 0 0 5px rgba(0,120,215,.3);
        }
</style>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    function validarDecimal() {
        if (Number.isNaN(Number($("#produtoPreco").val()))) {
            $("#produtoPreco").val("0");
        }
    }
</script>