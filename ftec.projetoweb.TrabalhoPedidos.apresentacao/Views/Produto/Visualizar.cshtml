@model ProdutoModel

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div class="page-container">
    <div class="product-card">

        <h1>Detalhes do Produto</h1>

        <div class="info-group">
            <span class="label">Categoria</span>
            <span class="value">@ViewBag.categoria</span>
        </div>

        <div class="info-group">
            <span class="label">Nome</span>
            <span class="value">@Model.Nome</span>
        </div>

        <div class="info-group">
            <span class="label">Quantidade em Estoque</span>
            <span class="value">@Model.QuantidadeEstoque</span>
        </div>

        <div class="info-group">
            <span class="label">Preço</span>
            <span class="value">R$ @Model.Preco</span>
        </div>

        <div class="info-group">
            <span class="label">Código</span>
            <span class="value">@Model.Codigo</span>
        </div>

        <div class="info-group">
            <span class="label">Descrição</span>
            <span class="value">@Model.Descricao</span>
        </div>

        <div class="info-group">
            <span class="label">Disponível</span>
            <span class="value">@(Model.Disponivel ? "Sim" : "Não")</span>
        </div>

        <div class="info-group">
            <span class="label">Estoque Mínimo para Venda</span>
            <span class="value">@Model.EstoqueMinimoVenda</span>
        </div>

        <div class="action-buttons">

            @if (DadosTeste.usuarioLogado != null && DadosTeste.usuarioLogado.funcao == 0)
            {
                <a class="btn-comprar"
                   asp-controller="Pedido"
                   asp-action="Create"
                   asp-route-produtoId="@Model.Id">
                    Comprar
                </a>
            }
            <a class="btn-avaliacoes"
               asp-controller="Avaliacao"
               asp-action="AvaliacoesProduto"
               asp-route-produtoId="@Model.Id">
                Avaliações
            </a>

        </div>

    </div>
</div>

                <style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #f1f3f6;
    }

    .page-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 25px;
        display: flex;
        justify-content: center;
    }

    .product-card {
        width: 100%;
        max-width: 650px;
        background: white;
        border-radius: 12px;
        padding: 35px;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        transition: .25s;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,.15);
        }

        .product-card h1 {
            margin: 0 0 30px;
            text-align: center;
            font-size: 28px;
            color: #333;
        }

    .info-group {
        display: flex;
        flex-direction: column;
        padding: 15px 0;
        border-bottom: 1px solid #eee;
    }

        .info-group:last-of-type {
            border-bottom: none;
        }

    .label {
        font-weight: bold;
        color: #555;
        margin-bottom: 6px;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: .5px;
    }

    .value {
        color: #333;
        font-size: 16px;
        word-break: break-word;
    }

    .action-buttons {
        display: flex;
        gap: 10px;
        margin-top: 30px;
    }

        .action-buttons a {
            flex: 1;
            padding: 12px;
            border-radius: 8px;
            text-align: center;
            text-decoration: none;
            font-weight: bold;
            transition: .2s;
        }

    .btn-comprar {
        background: #28a745;
        color: white;
    }

        .btn-comprar:hover {
            background: #218838;
        }

    .btn-avaliacoes {
        background: #007bff;
        color: white;
    }

        .btn-avaliacoes:hover {
            background: #0069d9;
        }

</style>