    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div class="page-container">
    <div class="form-card">

        <h1>Nova Categoria</h1>

        <form method="post"
              asp-controller="Categoria"
              asp-action="Inserir">
            <div class="form-group">
                <label>Nome da Categoria</label>
                <input type="text"
                       name="categoria.Nome" />
            </div>

            <div class="form-group">
                <label>Descrição da Categoria</label>
                <input type="text"
                       name="categoria.Descricao" />
            </div>

            <div class="action-buttons">

                <button type="submit" class="btn-salvar">
                    Salvar
                </button>

                <a class="btn-cancelar"
                   asp-controller="Categoria"
                   asp-action="Index">
                    Cancelar
                </a>

            </div>

        </form>

    </div>
</div>

<style>
    body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: #f4f6f9;
    }

    .page-container {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .form-card {
        width: 100%;
        max-width: 500px;
        background: white;
        padding: 35px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,.15);
    }

        .form-card h1 {
            text-align: center;
            margin-bottom: 30px;
            color: #333;
            font-size: 28px;
        }

    .form-group {
        display: flex;
        flex-direction: column;
        margin-bottom: 20px;
    }

        .form-group label {
            margin-bottom: 6px;
            font-weight: bold;
            color: #555;
        }

        .form-group input {
            padding: 12px;
            border: 1px solid #dcdcdc;
            border-radius: 6px;
            font-size: 14px;
            transition: .3s;
        }

            .form-group input:focus {
                outline: none;
                border-color: #0078d7;
                box-shadow: 0 0 5px rgba(0,120,215,.3);
            }

    .action-buttons {
        display: flex;
        gap: 10px;
        margin-top: 25px;
        flex-wrap: wrap;
    }

    .btn-salvar,
    .btn-excluir,
    .btn-cancelar {
        flex: 1;
        text-align: center;
        padding: 12px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: bold;
        transition: .3s;
        border: none;
        cursor: pointer;
    }

    .btn-salvar {
        background: #28a745;
        color: white;
    }

        .btn-salvar:hover {
            background: #218838;
        }

    .btn-excluir {
        background: #dc3545;
        color: white;
    }

        .btn-excluir:hover {
            background: #c82333;
            color: white;
        }

    .btn-cancelar {
        background: #6c757d;
        color: white;
    }

        .btn-cancelar:hover {
            background: #5a6268;
            color: white;
        }
</style>