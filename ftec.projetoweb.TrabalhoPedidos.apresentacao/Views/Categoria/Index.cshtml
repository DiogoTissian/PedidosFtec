@model List<CategoriaModel>

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<div class="page-container">
	<div class="content-card">

		<h1>Categorias</h1>

		<div class="toolbar">
			<span class="total-registros">
				Total: @Model.Count
			</span>

			<a class="btn-novo"
			   asp-controller="Categoria"
			   asp-action="Create">
				Nova Categoria
			</a>
		</div>

		@if (Model != null && Model.Count > 0)
		{
			<table class="stats-table">
				<thead>
					<tr>
						<th>Nome</th>
						<th>Descrição</th>
						<th width="120">Ações</th>
					</tr>
				</thead>
				<tbody>
					@foreach (CategoriaModel categoria in Model)
					{
						<tr>
							<td>@categoria.Nome</td>
							<td>@categoria.Descricao</td>
							<td>
								<a class="btn-editar"
								   asp-controller="Categoria"
								   asp-action="Edit"
								   asp-route-id="@categoria.Id">
									Editar
								</a>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
		else
		{
			<div class="empty-message">
				Sem categorias cadastradas.
			</div>
		}
	</div>
</div>

<style>
	body {
		margin: 0;
		font-family: Arial, Helvetica, sans-serif;
		background: #f4f6f9;
	}

	.page-container {
		padding: 30px;
	}

	.content-card {
		background: white;
		border-radius: 12px;
		padding: 30px;
		box-shadow: 0 4px 15px rgba(0,0,0,.15);
		overflow-x: auto;
	}

		.content-card h1 {
			text-align: center;
			color: #333;
			margin-bottom: 30px;
		}

	.toolbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 25px;
		flex-wrap: wrap;
		gap: 10px;
	}

	.total-registros {
		font-weight: bold;
		color: #555;
		font-size: 16px;
	}

	.stats-table {
		width: 100%;
		border-collapse: collapse;
	}

		.stats-table thead {
			background: #0078d7;
			color: white;
		}

		.stats-table th,
		.stats-table td {
			padding: 12px 15px;
			text-align: left;
		}

		.stats-table tbody tr {
			border-bottom: 1px solid #e5e5e5;
		}

			.stats-table tbody tr:nth-child(even) {
				background: #f8f9fb;
			}

			.stats-table tbody tr:hover {
				background: #eef5ff;
			}

	.btn-novo {
		background: #28a745;
		color: white;
		text-decoration: none;
		padding: 10px 18px;
		border-radius: 6px;
		font-weight: bold;
		transition: .3s;
	}

		.btn-novo:hover {
			background: #218838;
			color: white;
		}

	.btn-editar {
		background: #0078d7;
		color: white;
		text-decoration: none;
		padding: 8px 14px;
		border-radius: 6px;
		font-size: 14px;
		font-weight: bold;
		display: inline-block;
		transition: .3s;
	}

		.btn-editar:hover {
			background: #005fa3;
			color: white;
		}

	.empty-message {
		padding: 20px;
		text-align: center;
		color: #777;
		background: #fafafa;
		border: 1px dashed #ccc;
		border-radius: 8px;
	}
</style>